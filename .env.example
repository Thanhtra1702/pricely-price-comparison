# Sao chép file này thành .env và điền credential read-only của MinIO.
MINIO_ENDPOINT=https://minio.example.internal
MINIO_ACCESS_KEY=replace-with-read-only-key
MINIO_SECRET_KEY=replace-with-read-only-secret
MINIO_BUCKET=supermarket-lakehouse
MINIO_PREFIX=gold
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:3b
EMBEDDING_MODEL=bge-m3:latest
POSTGRES_PASSWORD=replace-with-a-strong-unique-password
CORS_ORIGINS=http://localhost:3000
